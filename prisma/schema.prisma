generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int        @id @default(autoincrement())
  username      String     @unique
  password_hash String
  full_name     String
  email         String?    @unique
  phone         String?    @unique
  avatar_url    String?
  role_id       Int
  user_status   UserStatus @default(ACTIVE)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  warehouse_id  Int?
  role          Role       @relation(fields: [role_id], references: [id])
  warehouse     Warehouse? @relation(fields: [warehouse_id], references: [id])

  @@index([role_id], map: "users_role_id_fkey")
  @@index([warehouse_id], map: "users_warehouse_id_fkey")
  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  is_active   Boolean          @default(true)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  module      String
  action      String
  is_active   Boolean          @default(true)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  role_id       Int
  permission_id Int
  assigned_at   DateTime   @default(now())
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([permission_id], map: "role_permissions_permission_id_fkey")
  @@map("role_permissions")
}

model ProductCategory {
  id          Int                  @id @default(autoincrement())
  code        String               @unique
  name        String
  description String?
  parent_id   Int?
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  parent      ProductCategory?     @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children    ProductCategory[]    @relation("CategoryHierarchy")
  products    ProductCategoryMap[]

  @@index([parent_id], map: "product_categories_parent_id_fkey")
  @@map("product_categories")
}

model Brand {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  name       String
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  products   Product[]

  @@map("brands")
}

model Manufacturer {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  name       String
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  products   Product[]

  @@map("manufacturers")
}

model UnitOfMeasure {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  name         String
  uom_type     UomType
  is_active    Boolean      @default(true)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  product_uoms ProductUom[]
  products     Product[]

  @@map("units_of_measure")
}

model Product {
  id                 Int                  @id @default(autoincrement())
  code               String               @unique
  name               String
  description        String?              @db.Text
  product_type       ProductType          @default(GOODS)
  product_status     ProductStatus        @default(ACTIVE)
  brand_id           Int?
  manufacturer_id    Int?
  base_uom_id        Int
  has_batch          Boolean              @default(false)
  min_stock          Decimal?             @db.Decimal(15, 3)
  max_stock          Decimal?             @db.Decimal(15, 3)
  storage_conditions String?
  image_url          String?
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  expiry_date        DateTime?
  production_date    DateTime?
  warehouse_id       Int?
  inventories        Inventory[]
  categories         ProductCategoryMap[]
  productSuppliers   ProductSupplier[]
  uoms               ProductUom[]
  base_uom           UnitOfMeasure        @relation(fields: [base_uom_id], references: [id])
  brand              Brand?               @relation(fields: [brand_id], references: [id])
  manufacturer       Manufacturer?        @relation(fields: [manufacturer_id], references: [id])
  warehouse          Warehouse?           @relation(fields: [warehouse_id], references: [id])

  @@index([brand_id], map: "products_brand_id_fkey")
  @@index([manufacturer_id], map: "products_manufacturer_id_fkey")
  @@index([warehouse_id], map: "products_warehouse_id_fkey")
  @@index([base_uom_id], map: "products_base_uom_id_fkey")
  @@map("products")
}

model ProductCategoryMap {
  product_id  Int
  category_id Int
  assigned_at DateTime        @default(now())
  category    ProductCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([product_id, category_id])
  @@index([category_id], map: "product_category_map_category_id_fkey")
  @@map("product_category_map")
}

model ProductUom {
  id                Int           @id @default(autoincrement())
  product_id        Int
  uom_id            Int
  conversion_factor Decimal       @db.Decimal(15, 6)
  is_default        Boolean       @default(false)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  product           Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  uom               UnitOfMeasure @relation(fields: [uom_id], references: [id])

  @@unique([product_id, uom_id])
  @@index([uom_id], map: "product_uoms_uom_id_fkey")
  @@map("product_uoms")
}

model Supplier {
  id               Int               @id @default(autoincrement())
  code             String            @unique
  name             String
  contact_person   String?
  phone            String?
  email            String?
  address          String?           @db.Text
  is_active        Boolean           @default(true)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  productSuppliers ProductSupplier[]

  @@map("suppliers")
}

model ProductSupplier {
  product_id     Int
  supplier_id    Int
  supplier_sku   String?
  purchase_price Decimal  @db.Decimal(15, 2)
  is_primary     Boolean  @default(false)
  product        Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  supplier       Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)

  @@id([product_id, supplier_id])
  @@index([supplier_id], map: "product_suppliers_supplier_id_fkey")
  @@map("product_suppliers")
}

model Warehouse {
  id         Int                 @id @default(autoincrement())
  code       String              @unique @db.VarChar(50)
  name       String              @db.VarChar(255)
  is_active  Boolean             @default(true)
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  products   Product[]
  users      User[]
  locations  WarehouseLocation[]

  @@map("warehouses")
}

model Inventory {
  id                    Int               @id @default(autoincrement())
  product_id            Int
  warehouse_location_id Int
  quantity              Decimal           @default(0.000) @db.Decimal(15, 3)
  reserved_quantity     Decimal           @default(0.000) @db.Decimal(15, 3)
  available_quantity    Decimal           @default(0.000) @db.Decimal(15, 3)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  product               Product           @relation(fields: [product_id], references: [id], onDelete: Cascade)
  location              WarehouseLocation @relation(fields: [warehouse_location_id], references: [id], onDelete: Cascade)

  @@unique([product_id, warehouse_location_id])
  @@index([product_id])
  @@index([warehouse_location_id])
  @@map("inventories")
}

model WarehouseLocation {
  id                Int            @id @default(autoincrement())
  warehouse_id      Int
  location_code     String         @unique @db.VarChar(100)
  zone_code         String?        @db.VarChar(50)
  aisle_code        String?        @db.VarChar(50)
  rack_code         String?        @db.VarChar(50)
  level_code        String?        @db.VarChar(50)
  bin_code          String?        @db.VarChar(50)
  full_path         String         @db.VarChar(255)
  location_status   LocationStatus @default(AVAILABLE)
  is_active         Boolean        @default(true)
  max_weight        Decimal?       @db.Decimal(15, 3)
  max_volume        Decimal?       @db.Decimal(15, 3)
  current_weight    Decimal        @default(0.000) @db.Decimal(15, 3)
  current_volume    Decimal        @default(0.000) @db.Decimal(15, 3)
  occupancy_percent Decimal        @default(0.00) @db.Decimal(5, 2)
  storage_condition StorageType    @default(AMBIENT)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  inventories       Inventory[]
  warehouse         Warehouse      @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@index([warehouse_id], map: "warehouse_locations_warehouse_id_fkey")
  @@map("warehouse_locations")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductType {
  GOODS
  MATERIAL
  CONSUMABLE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum UomType {
  WEIGHT
  VOLUME
  LENGTH
  QUANTITY
  PACK
}

enum LocationStatus {
  AVAILABLE
  PARTIAL
  FULL
  MAINTENANCE
}

enum StorageType {
  AMBIENT
  CHILLED
  FROZEN
  DRY
}
