model StockCount {
  id          Int                    @id @default(autoincrement())
  code        String                 @unique @map("stock_count_code")
  type        StockCountType         @default(PERIODIC)
  scope_type  StockCountScope        @default(FULL)
  description String?                @db.Text
  status      StockCountStatus       @default(DRAFT)
  created_by  Int
  approved_by Int?
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt
  adjustments StockCountAdjustment[]
  details     StockCountDetail[]
  approver    User?                  @relation("StockCountApprover", fields: [approved_by], references: [id])
  creator     User                   @relation("StockCountCreator", fields: [created_by], references: [id])

  @@index([created_by])
  @@index([approved_by])
  @@map("stock_counts")
}

model StockCountDetail {
  id                    Int               @id @default(autoincrement())
  stock_count_id        Int
  warehouse_location_id Int
  product_id            Int
  lot_id                Int?
  system_quantity       Decimal           @db.Decimal(15, 3)
  counted_quantity      Decimal?          @db.Decimal(15, 3)
  variance_quantity     Decimal?          @db.Decimal(15, 3)
  unit_price            Decimal?          @db.Decimal(15, 2)
  variance_reason       String?           @db.Text
  is_confirmed          Boolean           @default(false)
  counted_by            Int?
  counted_at            DateTime?
  counter               User?             @relation("StockCountDetailCounter", fields: [counted_by], references: [id])
  lot                   ProductLot?       @relation(fields: [lot_id], references: [id])
  product               Product           @relation(fields: [product_id], references: [id])
  stock_count           StockCount        @relation(fields: [stock_count_id], references: [id], onDelete: Cascade)
  location              WarehouseLocation @relation(fields: [warehouse_location_id], references: [id])

  @@index([stock_count_id])
  @@index([warehouse_location_id])
  @@index([product_id])
  @@index([lot_id])
  @@index([counted_by])
  @@map("stock_count_details")
}

model StockCountAdjustment {
  id                    Int               @id @default(autoincrement())
  stock_count_id        Int
  stock_count_detail_id Int
  warehouse_location_id Int
  product_id            Int
  lot_id                Int?
  adjustment_type       AdjustmentType
  adjustment_quantity   Decimal           @db.Decimal(15, 3)
  note                  String?           @db.Text
  created_by            Int
  created_at            DateTime          @default(now())
  creator               User              @relation("StockCountAdjustmentCreator", fields: [created_by], references: [id])
  lot                   ProductLot?       @relation(fields: [lot_id], references: [id])
  product               Product           @relation(fields: [product_id], references: [id])
  stock_count           StockCount        @relation(fields: [stock_count_id], references: [id], onDelete: Cascade)
  location              WarehouseLocation @relation(fields: [warehouse_location_id], references: [id])

  @@index([stock_count_id])
  @@index([stock_count_detail_id])
  @@index([created_by])
  @@index([lot_id], map: "stock_count_adjustments_lot_id_fkey")
  @@index([product_id], map: "stock_count_adjustments_product_id_fkey")
  @@index([warehouse_location_id], map: "stock_count_adjustments_warehouse_location_id_fkey")
  @@map("stock_count_adjustments")
}

enum StockCountType {
  PERIODIC
  AD_HOC
}

enum StockCountScope {
  FULL
  ZONE
  PRODUCT
  LOT
}

enum StockCountStatus {
  DRAFT
  COUNTING
  COMPLETED
  APPROVED
  CANCELLED
}

enum AdjustmentType {
  INCREASE
  DECREASE
}
