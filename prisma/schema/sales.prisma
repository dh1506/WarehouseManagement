model SalesImportBatch {
  id              Int                @id @default(autoincrement())
  batch_code      String             @unique @db.VarChar(255)
  source          String             @db.VarChar(50)
  status          String             @default("PENDING") @db.VarChar(50)
  total_records   Int                @default(0)
  success_records Int                @default(0)
  error_records   Int                @default(0)
  error_log       Json?
  created_by      Int
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  creator         User               @relation("SalesBatchCreator", fields: [created_by], references: [id])
  transactions    SalesTransaction[]

  @@index([created_by])
  @@map("sales_import_batches")
}

model SalesTransaction {
  id                    Int               @id @default(autoincrement())
  batch_id              Int
  warehouse_location_id Int
  transaction_code      String            @db.VarChar(255)
  transaction_type      String            @db.VarChar(50)
  transaction_date      DateTime
  product_id            Int
  quantity              Decimal           @db.Decimal(15, 3)
  unit_price            Decimal           @db.Decimal(15, 2)
  promo_discount_amount Decimal           @default(0.00) @db.Decimal(15, 2)
  net_amount            Decimal           @db.Decimal(15, 2)
  is_valid              Boolean           @default(true)
  is_inventory_updated  Boolean           @default(false)
  validation_note       String?           @db.Text
  created_at            DateTime          @default(now())
  batch                 SalesImportBatch  @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  product               Product           @relation(fields: [product_id], references: [id])
  location              WarehouseLocation @relation(fields: [warehouse_location_id], references: [id])

  @@unique([transaction_code, transaction_type, product_id], name: "unq_pos_transaction")
  @@index([batch_id])
  @@index([warehouse_location_id])
  @@index([product_id])
  @@map("sales_transactions")
}

model SalesDailySummary {
  id                    Int               @id @default(autoincrement())
  summary_date          DateTime          @db.Date
  warehouse_location_id Int
  product_id            Int
  total_sales_qty       Decimal           @default(0.000) @db.Decimal(15, 3)
  total_returned_qty    Decimal           @default(0.000) @db.Decimal(15, 3)
  net_sales_qty         Decimal           @default(0.000) @db.Decimal(15, 3)
  total_promo_amount    Decimal           @default(0.00) @db.Decimal(15, 2)
  total_revenue         Decimal           @default(0.00) @db.Decimal(15, 2)
  last_updated_at       DateTime          @default(now()) @updatedAt
  product               Product           @relation(fields: [product_id], references: [id])
  location              WarehouseLocation @relation(fields: [warehouse_location_id], references: [id])

  @@unique([summary_date, warehouse_location_id, product_id], name: "unq_daily_location_product")
  @@index([warehouse_location_id])
  @@index([product_id])
  @@map("sales_daily_summaries")
}
