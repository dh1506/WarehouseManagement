// ==================== MODULE QUẢN LÝ HỦY HÀNG ====================

// Bảng danh mục nguyên nhân hủy
model DisposalReason {
  id          Int      @id @default(autoincrement())
  name        String   @unique // VD: EXPIRED, DAMAGED, LOST, QUALITY_ISSUE
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  details StockDisposalDetail[]

  @@map("disposal_reasons")
}

// Bảng chính - Phiếu hủy hàng
model StockDisposal {
  id          Int                 @id @default(autoincrement())
  code        String              @unique @map("disposal_code") // VD: 'HUY-2026-001'
  description String?             @db.Text
  status      StockDisposalStatus @default(DRAFT) // DRAFT, PENDING, APPROVED, COMPLETED, CANCELLED
  created_by  Int
  approved_by Int?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt

  creator  User                   @relation("StockDisposalCreator", fields: [created_by], references: [id])
  approver User?                  @relation("StockDisposalApprover", fields: [approved_by], references: [id])
  details  StockDisposalDetail[]
  history  StockDisposalHistory[]

  @@index([created_by])
  @@index([approved_by])
  @@map("stock_disposals")
}

// Bảng lịch sử thay đổi trạng thái
model StockDisposalHistory {
  id                Int                 @id @default(autoincrement())
  stock_disposal_id Int
  status            StockDisposalStatus
  note              String?             @db.Text
  created_by        Int
  created_at        DateTime            @default(now())

  stock_disposal StockDisposal @relation(fields: [stock_disposal_id], references: [id], onDelete: Cascade)
  creator        User          @relation("StockDisposalHistoryCreator", fields: [created_by], references: [id])

  @@index([stock_disposal_id])
  @@index([created_by])
  @@map("stock_disposal_history")
}

// Bảng chi tiết hủy hàng
model StockDisposalDetail {
  id                    Int  @id @default(autoincrement())
  stock_disposal_id     Int
  warehouse_location_id Int
  product_id            Int
  lot_id                Int?
  reason_id             Int

  quantity    Decimal  @db.Decimal(15, 3)
  unit_price  Decimal? @db.Decimal(15, 2)
  reason_note String?  @db.Text // Ghi chú lý do chi tiết cho từng dòng

  stock_disposal StockDisposal     @relation(fields: [stock_disposal_id], references: [id], onDelete: Cascade)
  location       WarehouseLocation @relation(fields: [warehouse_location_id], references: [id])
  product        Product           @relation(fields: [product_id], references: [id])
  lot            ProductLot?       @relation(fields: [lot_id], references: [id])
  reason         DisposalReason    @relation(fields: [reason_id], references: [id])

  @@index([stock_disposal_id])
  @@index([warehouse_location_id])
  @@index([product_id])
  @@index([lot_id])
  @@index([reason_id])
  @@map("stock_disposal_details")
}

enum StockDisposalStatus {
  DRAFT
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}
